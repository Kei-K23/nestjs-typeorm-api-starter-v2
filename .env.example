# Application
APP_NAME="NestJS TypeORM API Starter"
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_typeorm_api_starter_db

# Auth
AUTH_PASSWORD_SALT_ROUNDS=10

# JWT Configuration
# Secrets must be at least 32 characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-min-32-chars
JWT_EXPIRATION=2592000000        # 15 minutes in ms
JWT_REFRESH_EXPIRATION=2592000000  # 30 days in ms

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS
# Development:  CORS_ORIGINS=*  (WARNING: allows all origins — shows a security warning)
# Production:   CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# AWS S3 (optional — only needed if using file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_BUCKET_NAME=
AWS_ENDPOINT=

# Email (SMTP settings are stored in the database via the settings module)
SMTP_FROM_NAME="NestJS TypeORM API Starter"

# OTP Mock
# NODE_ENV=development enables this by default. Set false to force real providers.
OTP_MOCK_ENABLED=true
OTP_MOCK_CODE=000000

# SMS Provider
SMS_POH_API_KEY=
SMS_POH_API_SECRET_KEY=
SMS_POH_BASE_API_URL=
SMS_POH_API_BRAND=
SMS_POH_API_SENDER_ID=
# Legacy SMS-only override for non-development environments.
# Mock Request ID: mock-request-id
SMS_MOCK_ENABLED=true
